# =====================================================
# Steven Villamizar — Portfolio environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local (already gitignored).
# =====================================================

# Anthropic API key — REQUIRED for the AI Copilot chat.
# Get one at https://console.anthropic.com/settings/keys
# IMPORTANT: If this key ever leaks (chat, screenshot, commit) ROTATE IT
# immediately at the Anthropic console. Do not reuse compromised keys.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# Optional — comma-separated list of allowed origins for the chat API.
# Same-host is always allowed automatically; *.vercel.app previews are too.
# Add custom domains here (e.g. https://stevencv.com).
ALLOWED_ORIGINS=https://cv-steven.vercel.app
